<Application x:Class="LibraryBorrowBook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LibraryBorrowBook"
             StartupUri="View/LoginWindow.xaml">
    <Application.Resources>

        <!-- Color Palette -->
        <Color x:Key="PrimaryOrange">#FF8C00</Color>
        <Color x:Key="LightOrange">#FFB347</Color>
        <Color x:Key="SoftYellow">#FFF3B0</Color>
        <Color x:Key="WarmWhite">#FFFDF5</Color>
        <Color x:Key="AccentOrange">#FF6B00</Color>
        <Color x:Key="TextDark">#3D2200</Color>
        <Color x:Key="BorderOrange">#FFAA33</Color>

        <SolidColorBrush x:Key="PrimaryOrangeBrush"  Color="{StaticResource PrimaryOrange}"/>
        <SolidColorBrush x:Key="LightOrangeBrush"    Color="{StaticResource LightOrange}"/>
        <SolidColorBrush x:Key="SoftYellowBrush"     Color="{StaticResource SoftYellow}"/>
        <SolidColorBrush x:Key="WarmWhiteBrush"      Color="{StaticResource WarmWhite}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush"   Color="{StaticResource AccentOrange}"/>
        <SolidColorBrush x:Key="TextDarkBrush"       Color="{StaticResource TextDark}"/>
        <SolidColorBrush x:Key="BorderOrangeBrush"   Color="{StaticResource BorderOrange}"/>

        <!-- Global Window Background -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WarmWhiteBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF8C00" Offset="0"/>
                        <GradientStop Color="#FF6B00" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFB347" Offset="0"/>
                                            <GradientStop Color="#FF8C00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#CC5500"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderOrangeBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label Style -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderOrangeBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="RowBackground" Value="{StaticResource WarmWhiteBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SoftYellowBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LightOrangeBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource LightOrangeBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- DataGridColumnHeader Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF8C00" Offset="0"/>
                        <GradientStop Color="#FFB347" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderOrangeBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
        <!-- Admin-only Button Style (Collapsed by default, shown via code-behind for admins) -->
        <Style x:Key="AdminOnlyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

    </Application.Resources>
</Application>
