<Window x:Class="LibraryBorrowBook.View.MyBorrow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook.View"
        mc:Ignorable="d"
        Title="Library — My Borrows" Height="500" Width="850"
        Background="{StaticResource WarmWhiteBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF8C00" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock Text="📋 My Borrows"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <Button x:Name="btnBack"
                        Content="← Back"
                        Width="90"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Click="btnBack_Click"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Grid.Column="0"
                    CornerRadius="8"
                    BorderThickness="1.5"
                    BorderBrush="{StaticResource BorderOrangeBrush}"
                    Margin="0,0,10,0">
                <DataGrid x:Name="dgBorrows"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="scReturn"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Borrow ID"
                                            Binding="{Binding BorrowId}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Reader"
                                            Binding="{Binding User.UserName}"
                                            Width="150"/>
                        <DataGridTextColumn Header="Book"
                                            Binding="{Binding Book.Title}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Side panel -->
            <Border Grid.Column="1"
                    CornerRadius="10"
                    Padding="12"
                    BorderThickness="1.5"
                    BorderBrush="{StaticResource BorderOrangeBrush}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFF3B0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Color="#FFAA33" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="Book Preview"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#CC5500"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <Border CornerRadius="6"
                            BorderBrush="{StaticResource LightOrangeBrush}"
                            BorderThickness="1">
                        <Image x:Name="imgBook" Width="180" Height="240" Stretch="Uniform"/>
                    </Border>
                    <Button x:Name="btnReturn"
                            Content="Return Book"
                            Width="160"
                            Height="36"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0"
                            Click="btnReturn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
