<Window x:Class="LibraryBorrowBook.View.FinesManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fines Management" Height="450" Width="800"
        Background="#FFFDF5E6" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Name="tbTitle" Text="💸 Fines Management" FontSize="22" FontWeight="Bold" Foreground="#FFD32F2F" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <!-- Add Manual Fine (Admin Only) -->
        <Border Name="panelAddFine" Grid.Row="1" Background="#FFFFE0" BorderBrush="#FFCC80" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="➕ Add Manual Fine (Damaged/Lost Book)" FontWeight="Bold" Foreground="#D2691E" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Select Borrow Record:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Name="cbBorrows" Grid.Column="1" Height="25" Margin="0,0,10,0" DisplayMemberPath="DisplayInfo" SelectedValuePath="BorrowId"/>
                    
                    <TextBlock Text="Amount:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Name="txtAmount" Grid.Column="3" Height="25" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Text="Reason:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Name="txtReason" Width="150" Height="25" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <Button Name="btnAddFine" Content="Create Fine" Width="80" Height="25" Background="#FFD32F2F" Foreground="White" BorderThickness="0" Click="btnAddFine_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid Name="dgFines" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderBrush="#FFEF9A9A" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding FineId}" Width="50"/>
                <DataGridTextColumn Header="Reader" Binding="{Binding Borrow.User.UserName}" Width="100"/>
                <DataGridTextColumn Header="Book" Binding="{Binding Borrow.Book.Title}" Width="*"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N0} VND}" Width="100"/>
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="150"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Unpaid">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Paid">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Action" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Mark as Paid" Click="btnMarkPaid_Click" Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}}" Background="#FF4CAF50" Foreground="White" BorderThickness="0" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button Name="btnBack" Grid.Row="3" Content="Back to Dashboard" Width="150" Height="30" HorizontalAlignment="Left" Margin="0,15,0,0" Click="btnBack_Click"/>
    </Grid>
</Window>
