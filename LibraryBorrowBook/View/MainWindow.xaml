<Window x:Class="LibraryBorrowBook.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook"
        mc:Ignorable="d"
        Title="Library — Book Catalog" Height="550" Width="900"
        Background="{StaticResource WarmWhiteBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top navigation bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF8C00" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock Text="📚 Library"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>


                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button Name="btnReaders"
                            Content="👥 Readers"
                            Width="100"
                            Height="32"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="btnReaders_Click"/>
                    <Button Name="btnCategories"
                            Content="🏷 Categories"
                            Width="110"
                            Height="32"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="btnCategories_Click"/>
                    <Button Name="btnAddBook"
                            Content="＋ Add Book"
                            Width="110"
                            Height="32"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="btnAddBook_Click"/>
                    <Button Name="btnFines"
                            Content="💸 Fines"
                            Width="90"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="btnFines_Click"/>
                    <Button Name="btnSettings"
                            Content="⚙ Settings"
                            Width="90"
                            Height="32"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="btnSettings_Click"/>
                    <Button Name="btnMyBorrow"
                            Content="My Borrows"
                            Width="110"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="btnMyBorrow_Click"/>
                    <Button Name="btnLogout"
                            Content="Logout"
                            Width="80"
                            Height="32"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dashboard Area -->
        <Grid Name="DashboardPanel" Grid.Row="1" Margin="10,10,10,0" Visibility="Collapsed">
            <UniformGrid Columns="3">
                <Border Background="#FFFFE0" BorderBrush="#FFCC80" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Total Books" FontSize="14" Foreground="#8B4500" HorizontalAlignment="Center"/>
                        <TextBlock Name="txtTotalBooks" Text="0" FontSize="20" FontWeight="Bold" Foreground="#D2691E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#E6F2FF" BorderBrush="#99CCFF" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Active Borrows" FontSize="14" Foreground="#004C99" HorizontalAlignment="Center"/>
                        <TextBlock Name="txtActiveBorrows" Text="0" FontSize="20" FontWeight="Bold" Foreground="#0066CC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#E6FFE6" BorderBrush="#99FF99" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Total Readers" FontSize="14" Foreground="#006600" HorizontalAlignment="Center"/>
                        <TextBlock Name="txtTotalReaders" Text="0" FontSize="20" FontWeight="Bold" Foreground="#009900" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>

        <!-- Search Bar Area -->
        <Grid Grid.Row="2" Margin="10,10,20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="🔍" Foreground="#FF8C00" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
                <TextBox x:Name="txtSearch" 
                         Width="250" Height="28" 
                         VerticalContentAlignment="Center"
                         ToolTip="Search by Title or Author"
                         TextChanged="txtSearch_TextChanged"
                         BorderBrush="#FFCC80"
                         BorderThickness="1.5"
                         Padding="4,0,4,0"/>
            </StackPanel>
        </Grid>

        <!-- Book cards -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="10">
            <ItemsControl x:Name="icBooks">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10"
                                Width="240"
                                CornerRadius="10"
                                Padding="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFF3B0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFB347" Offset="0"/>
                                    <GradientStop Color="#FF8C00" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1.5</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Color="#FFAA33" Opacity="0.18"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#CC5500"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"/>

                                <Grid Height="140" Margin="0,0,0,8">
                                    <!-- Placeholder shown behind when no image -->
                                    <TextBlock Text="📖"
                                               FontSize="50"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#FFCC80"/>
                                    <Image Source="{Binding Image}" Height="140" Stretch="Uniform"/>
                                </Grid>

                                <TextBlock Text="{Binding Author}"
                                           Foreground="#3D2200"
                                           FontSize="12"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding YearPublish}"
                                           Foreground="#7A4500"
                                           FontSize="12"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Publisher}"
                                           Foreground="#7A4500"
                                           FontSize="12"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Category.CategoryName}"
                                           Foreground="#FF8C00"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Margin="0,0,0,4"/>

                                <WrapPanel HorizontalAlignment="Center" Margin="0,5,0,0">
                                    <Button Content="Info"
                                            Width="60"
                                            Height="28"
                                            Margin="0,0,5,5"
                                            Background="#FF2196F3" Foreground="White" BorderThickness="0"
                                            Click="btnInfo_Click"/>
                                    <Button Content="Borrow"
                                            Width="60"
                                            Height="28"
                                            Margin="0,0,5,5"
                                            Click="btnBorrow_Click"/>
                                    <Button Content="Update"
                                            Width="60"
                                            Height="28"
                                            Margin="0,0,5,5"
                                            Click="btnUpdate_Click"
                                            Style="{DynamicResource AdminOnlyButtonStyle}"/>
                                    <Button Content="Delete"
                                            Width="60"
                                            Height="28"
                                            Margin="0,0,0,5"
                                            Click="btnDelete_Click"
                                            Style="{DynamicResource AdminOnlyButtonStyle}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
