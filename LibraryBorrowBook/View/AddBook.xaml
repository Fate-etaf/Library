<Window x:Class="LibraryBorrowBook.View.AddBook"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook.View"
        mc:Ignorable="d"
        Title="Library — Add Book" Height="520" Width="820"
        Background="{StaticResource WarmWhiteBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF8C00" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <TextBlock Text="➕ Add New Book"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <Button x:Name="btnBack"
                        Content="← Back"
                        Width="90"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Click="btnBack_Click"/>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Book image preview -->
            <Border Grid.Column="0"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderOrangeBrush}"
                    BorderThickness="1.5"
                    Margin="0,0,12,0"
                    Padding="6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFF3B0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="📖"
                               FontSize="50"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#FFCC80"
                               x:Name="txtPlaceholder"/>
                    <Image x:Name="imgPreview" Stretch="Uniform"/>
                </Grid>
            </Border>

            <!-- Labels -->
            <StackPanel Grid.Column="1" Margin="0,4,8,0" VerticalAlignment="Top">
                <Label Content="Title *"        Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Author"         Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Publisher"      Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Year Publish *" Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Quantity"       Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Category ID"    Height="46" VerticalContentAlignment="Center"/>
                <Label Content="Image URL"      Height="46" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Input fields -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,8,0,0">
                <TextBox x:Name="txtTitle"       Height="36" Margin="0,4,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtAuthor"      Height="36" Margin="0,0,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtPublisher"   Height="36" Margin="0,0,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtYearPublish" Height="36" Margin="0,0,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtQuantity"    Height="36" Margin="0,0,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtCategoryId"  Height="36" Margin="0,0,0,6" Width="300" HorizontalAlignment="Left"/>
                <TextBox x:Name="txtImageUrl"    Height="36" Margin="0,0,0,14" Width="300" HorizontalAlignment="Left"
                         TextChanged="txtImageUrl_TextChanged"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnAdd"
                            Content="Add Book"
                            Width="140"
                            Height="38"
                            Margin="0,0,10,0"
                            Click="btnAdd_Click"/>
                    <Button x:Name="btnClear"
                            Content="Clear"
                            Width="100"
                            Height="38"
                            Click="btnClear_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
