<Window x:Class="LibraryBorrowBook.View.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook.View"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Label Content="REGISTER" FontSize="24" HorizontalAlignment="Center" Margin="10"/>
            <TextBox x:Name="UsernameTextBox" Width="200" Margin="10" Text="Username"/>
            <TextBox x:Name="PasswordTextBox" Width="200" Margin="10" Text="Password"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnBack" Content="Back to Login" Width="80" Margin="10" Click="btnBack_Click"/>
                <Button x:Name="btnRegister" Content="Register" Width="80" Margin="10" Click="btnRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
