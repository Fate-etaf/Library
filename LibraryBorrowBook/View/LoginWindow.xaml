<Window x:Class="LibraryBorrowBook.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook.View"
        mc:Ignorable="d"
        Title="Library — Login" Height="450" Width="800"
        Background="{StaticResource WarmWhiteBrush}">

    <Grid VerticalAlignment="Center">
        <!-- Decorative header band -->
        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF8C00" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="0.5"/>
                    <GradientStop Color="#FF8C00" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border Width="360"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="36,32"
                CornerRadius="14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#FFF3B0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#FFAA33" Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>
                <!-- Title -->
                <TextBlock Text="📚 Library Login"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#FF6B00"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Foreground="#CC5500" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername" Height="36" Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Foreground="#CC5500" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="txtPassword" Height="36" Margin="0,0,0,22"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnLogin"
                            Content="Login"
                            Width="110"
                            Height="36"
                            Margin="0,0,12,0"
                            Click="btnLogin_Click"/>
                    <Button x:Name="btnRegister"
                            Content="Register"
                            Width="110"
                            Height="36"
                            Click="btnRegister_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
