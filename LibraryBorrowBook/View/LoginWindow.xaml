<Window x:Class="LibraryBorrowBook.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryBorrowBook.View"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid VerticalAlignment="Center">
        <StackPanel Margin="-60,-80,0,0">
            <Label Content="LOGIN" FontSize="24" HorizontalAlignment="Center" Margin="100,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Content="Username:" Width="80" Margin="10"/>
                <TextBox x:Name="txtUsername" Width="200" Margin="10"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Content="Password:" Width="80" Margin="10"/>
                <TextBox x:Name="txtPassword" Width="200" Margin="10" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="100,0,0,0">
                <Button x:Name="btnLogin" Content="Login" Width="80" Margin="10" Click="btnLogin_Click"/>
                <Button x:Name="btnRegister" Content="Register" Width="80" Margin="10" Click="btnRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
