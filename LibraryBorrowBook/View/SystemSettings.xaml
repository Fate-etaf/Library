<Window x:Class="LibraryBorrowBook.View.SystemSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="System Settings" Height="400" Width="500"
        Background="#FFFDF5E6" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚙ System Configuration" FontSize="22" FontWeight="Bold" Foreground="#FF8C00" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="spSettings" Orientation="Vertical">
                <!-- Settings will be generated dynamically in code-behind -->
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="btnSave" Grid.Column="0" Content="Save Changes" Height="35" Width="120" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnSave_Click"/>
            <Button Name="btnBack" Grid.Column="1" Content="Back to Dashboard" Height="35" Width="140" Background="#FF757575" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnBack_Click"/>
        </Grid>
    </Grid>
</Window>
